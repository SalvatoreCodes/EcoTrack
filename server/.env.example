# EcoTrack server keys. Copy to .env and fill in. Server runs with sample/synthetic data if blank.
PORT=8787
# OpenRouteService (routing): https://openrouteservice.org/dev/#/signup
ORS_KEY=
# WAQI air-quality token: https://aqicn.org/data-platform/token/
WAQI_TOKEN=
# TomTom traffic flow: https://developer.tomtom.com/
TOMTOM_KEY=
# Anthropic (assistant): https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
